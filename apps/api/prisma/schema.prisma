// Prisma schema for eventaat.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  RESTAURANT_ADMIN
  PLATFORM_ADMIN
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  phone        String?
  role         Role     @default(CUSTOMER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurantAssignments RestaurantAdmin[]

  @@map("users")
}

model Restaurant {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  phone       String?
  address     String
  city        String
  area        String?
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  admins RestaurantAdmin[]

  @@map("restaurants")
}

/// Join table that links a RESTAURANT_ADMIN user to one or more restaurants.
/// One user can manage multiple restaurants; one restaurant can have multiple admins.
model RestaurantAdmin {
  userId       String @map("user_id") @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now()) @map("assigned_at")

  @@id([userId, restaurantId])
  @@map("restaurant_admins")
}
