// Prisma schema for eventaat.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  RESTAURANT_ADMIN
  PLATFORM_ADMIN
}

enum GuestType {
  FAMILY
  YOUTH
  MIXED
  BUSINESS
  OTHER
}

enum SeatingPreference {
  INDOOR
  OUTDOOR
  NO_PREFERENCE
}

enum BookingType {
  STANDARD
  EVENT_NIGHT
  VIP
  OCCASION
  OTHER
}

enum ReservationStatus {
  PENDING
  HELD
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

/// Public-facing contact or social entry for a restaurant.
enum RestaurantContactType {
  PHONE
  WHATSAPP
  INSTAGRAM
  WEBSITE
  EMAIL
  OTHER
}

enum RestaurantEventStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  phone        String?
  role         Role     @default(CUSTOMER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurantAssignments RestaurantAdmin[]
  reservations                 Reservation[]
  reservationStatusAsActor     ReservationStatusHistory[] @relation("ReservationStatusChangeActor")
  eventsCreated                RestaurantEvent[]         @relation("EventCreatedBy")
  eventsApproved               RestaurantEvent[]         @relation("EventApprovedBy")

  @@map("users")
}

model Restaurant {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  phone       String?
  address     String
  city        String
  area        String?
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  isActive    Boolean  @default(true) @map("is_active")
  /// Optional public URLs and copy (file URLs until uploads exist).
  websiteUrl        String? @map("website_url") @db.VarChar(2048)
  menuUrl           String? @map("menu_url") @db.VarChar(2048)
  locationUrl       String? @map("location_url") @db.VarChar(2048)
  instagramUrl      String? @map("instagram_url") @db.VarChar(2048)
  coverImageUrl     String? @map("cover_image_url") @db.VarChar(2048)
  profileImageUrl   String? @map("profile_image_url") @db.VarChar(2048)
  shortDescription  String? @map("short_description")
  profileDescription String? @map("profile_description")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  admins RestaurantAdmin[]
  tables RestaurantTable[]
  reservations Reservation[]

  operatingSettings RestaurantOperatingSettings?
  openingHours     RestaurantOpeningHour[]
  contacts         RestaurantContact[]
  events           RestaurantEvent[]

  @@map("restaurants")
}

/// Special event night (singer, VIP dinner, etc.). Public listing requires APPROVED + isActive; booking is a future step.
model RestaurantEvent {
  id        String  @id @default(uuid()) @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid
  title     String
  description String?
  startsAt  DateTime @map("starts_at")
  endsAt    DateTime @map("ends_at")
  status    RestaurantEventStatus @default(PENDING)
  isActive  Boolean @default(true) @map("is_active")
  isFree    Boolean @default(true) @map("is_free")
  price     Decimal? @map("price") @db.Decimal(14, 2)
  currency  String  @default("IQD") @map("currency") @db.VarChar(8)
  capacity  Int?    @map("capacity")
  seatsAvailableNote String? @map("seats_available_note")
  specialMenuDescription String? @map("special_menu_description")
  specialMenuUrl  String? @map("special_menu_url") @db.VarChar(2048)
  whatIsIncluded  String? @map("what_is_included")
  entertainmentInfo String? @map("entertainment_info")
  coverImageUrl  String? @map("cover_image_url") @db.VarChar(2048)
  galleryImageUrls Json?  @map("gallery_image_urls")
  rejectionReason String? @map("rejection_reason")
  approvedAt      DateTime? @map("approved_at")
  approvedByUserId String? @map("approved_by_user_id") @db.Uuid
  createdByUserId String? @map("created_by_user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  restaurant  Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  approvedBy  User?      @relation("EventApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  createdBy   User?      @relation("EventCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([restaurantId, status])
  @@index([startsAt])
  @@map("restaurant_events")
}

/// Business rules and defaults for requests (one row per restaurant).
/// Time-of-day and calendar checks use the server / local Date behavior; no per-venue IANA zone yet.
model RestaurantOperatingSettings {
  id         String   @id @default(uuid()) @db.Uuid
  restaurantId String  @unique @map("restaurant_id") @db.Uuid
  defaultReservationDurationMinutes Int @default(90) @map("default_reservation_duration_minutes")
  minPartySize  Int   @default(1) @map("min_party_size")
  maxPartySize  Int?  @map("max_party_size")
  manualApprovalRequired Boolean @default(true) @map("manual_approval_required")
  acceptsReservations Boolean   @default(true) @map("accepts_reservations")
  advanceBookingDays  Int        @default(14) @map("advance_booking_days")
  sameDayCutoffMinutes  Int     @default(60) @map("same_day_cutoff_minutes")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("restaurant_operating_settings")
}

/// Weekly schedule. dayOfWeek: 0=Sunday .. 6=Saturday (JavaScript getDay()).
/// opensAt / closesAt are "HH:mm" 24h strings in local wall-clock for the business day.
model RestaurantOpeningHour {
  id        String   @id @default(uuid()) @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid
  dayOfWeek  Int     @map("day_of_week")
  opensAt    String  @map("opens_at")
  closesAt   String  @map("closes_at")
  isClosed   Boolean @default(false) @map("is_closed")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, dayOfWeek])
  @@index([restaurantId])
  @@map("restaurant_opening_hours")
}

/// Structured contact for profile; at most one primary per (restaurant, type) via service.
model RestaurantContact {
  id           String  @id @default(uuid()) @db.Uuid
  restaurantId String  @map("restaurant_id") @db.Uuid
  label        String
  type         RestaurantContactType
  value        String
  isPrimary    Boolean @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([restaurantId, type])
  @@map("restaurant_contacts")
}

model RestaurantTable {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  name         String
  capacity     Int
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@map("restaurant_tables")
}

model Reservation {
  id                String            @id @default(uuid()) @db.Uuid
  customerId        String            @map("customer_id") @db.Uuid
  restaurantId      String            @map("restaurant_id") @db.Uuid
  tableId           String?           @map("table_id") @db.Uuid
  partySize         Int               @map("party_size")
  startAt           DateTime          @map("start_at")
  endAt             DateTime          @map("end_at")
  status            ReservationStatus @default(PENDING)
  guestType         GuestType         @map("guest_type")
  seatingPreference SeatingPreference @map("seating_preference")
  bookingType       BookingType      @map("booking_type")
  occasionNote      String?           @map("occasion_note")
  customerPhone     String?           @map("customer_phone")
  specialRequest    String?          @map("special_request")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  customer   User            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table         RestaurantTable?            @relation(fields: [tableId], references: [id], onDelete: SetNull)
  statusHistory ReservationStatusHistory[]

  @@index([restaurantId])
  @@index([tableId, startAt, endAt])
  @@index([customerId])
  @@map("reservations")
}

model ReservationStatusHistory {
  id              String   @id @default(uuid()) @db.Uuid
  reservationId   String   @map("reservation_id") @db.Uuid
  changedByUserId String?  @map("changed_by_user_id") @db.Uuid
  fromStatus      ReservationStatus? @map("from_status")
  toStatus        ReservationStatus  @map("to_status")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  changedBy   User?        @relation("ReservationStatusChangeActor", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([reservationId])
  @@index([reservationId, createdAt])
  @@map("reservation_status_history")
}

/// Join table that links a RESTAURANT_ADMIN user to one or more restaurants.
/// One user can manage multiple restaurants; one restaurant can have multiple admins.
model RestaurantAdmin {
  userId       String @map("user_id") @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now()) @map("assigned_at")

  @@id([userId, restaurantId])
  @@map("restaurant_admins")
}
