# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Server
PORT=4000
NODE_ENV=development

# Set to 1 to print step-by-step bootstrap / Prisma $connect lines (troubleshooting only).
# EVENTAAT_DEBUG_BOOT=1

# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&connect_timeout=8
# connect_timeout (seconds) avoids indefinite hangs if the DB is unreachable.
DATABASE_URL=postgresql://eventaat:eventaat@localhost:5432/eventaat?schema=public&connect_timeout=8

# JWT — used to sign access tokens issued by /auth/login.
# Generate a strong secret with:  openssl rand -hex 32
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_EXPIRES_IN=7d
