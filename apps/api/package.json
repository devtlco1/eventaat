{
  "name": "@eventaat/api",
  "version": "0.0.1",
  "private": true,
  "description": "eventaat backend API (NestJS + Prisma + PostgreSQL)",
  "main": "dist/main.js",
  "scripts": {
    "predev": "npm run build -w @eventaat/shared",
    "dev": "nest start --watch",
    "prebuild": "npm run build -w @eventaat/shared",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "echo \"no tests yet\""
  },
  "dependencies": {
    "@eventaat/shared": "*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@prisma/client": "^5.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.5",
    "prisma": "^5.20.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
